<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Table
        visible="{employeeModel2>/tableVisible}"
        items="{employeeModel2>/Employee}">

        <columns>

            <Column>
                <Text text="{i18n>employeeName}"/>
            </Column>

            <Column>
                <Text text="{i18n>role}"/>
            </Column>

            <Column>
                <Text text="{i18n>status}"/>
            </Column>

            <Column>
                <Text text="{i18n>joiningDate}"/>
            </Column>

            <Column>
                <Text text="{i18n>department}"/>
            </Column>

            <Column>
                <Text text="{i18n>salary}"/>
            </Column>

            <Column>
                <Text text="{i18n>updateEmployee}"/>
            </Column>

            <Column>
                <Text text="{i18n>delete}"/>
            </Column>

        </columns>

        <items>

            <ColumnListItem>

                <cells>

                    <Text
                        text="{employeeModel2>name}"/>

                    <Text
                        text="{employeeModel2>role}"/>

                    <Text
                        text="{employeeModel2>status}"/>

                    <Text
                        text="{
                            path:'employeeModel2>joiningDate',
                            formatter:'.formatter.formatDate'
                        }"/>

                    <Text
                        text="{employeeModel2>department}"/>

                    <Text
                        text="{employeeModel2>salary}"/>

                    <Button
                        text="{i18n>updateEmployee}"
                        type="Emphasized"
                        press="onUpdate"/>

                    <Button
                        text="{i18n>delete}"
                        type="Reject"
                        press="onDelete"/>

                </cells>

            </ColumnListItem>

        </items>

    </Table>

</core:FragmentDefinition>