<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">

   <Dialog draggable="true"
       resizable="true"
       title="Form Fragment">
     <form:SimpleForm
        editable="true"
        layout="ResponsiveGridLayout">

        <Label text="First Name" />
        <Input id="idFirstName" value="{uiModel>/firstName}" />

        <Label text="Last Name" />
        <Input id="idLastName" value="{uiModel>/lastName}" />

        <Label text="Amount" />
        <Input id="idAmount" value="{uiModel>/amount}" />

        <Button
            text="Submit"
            press="onSubmit" />

    </form:SimpleForm>

    <beginButton>
        <Button text="ok" press="onSubmit" />
    </beginButton>

    <endButton>
        <Button text="Cancel" press="onCancel" />
    </endButton>

   </Dialog>

</core:FragmentDefinition>