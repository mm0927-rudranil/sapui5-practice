<mvc:View
    controllerName="demofiori.project1.controller.View4"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page title="{i18n>pageTitle}">

        <content>

            <!-- Form Fragment Container -->

            <!-- <VBox id="formContainer"/> -->

            <core:Fragment
            fragmentName="demofiori.project1.fragment.EmployeeForm"
            type="XML" />

            <Button
            text="{i18n>addEmployee}"
            press="onAdd"
            type="Emphasized" />

            <!-- Radio Button -->

            <RadioButtonGroup
                select="onViewChange">

                <buttons>

                    <RadioButton
                        text="{i18n>table}"
                        selected="true"/>

                    <RadioButton
                        text="{i18n>list}"/>

                </buttons>

            </RadioButtonGroup>

            <!-- Popover Button -->

            <Button
                text="{i18n>showPopover}"
                press="openPopover"/>

            <!-- Table Fragment Container -->

            <VBox id="tableContainer"/>

            <!-- List Fragment Container -->

            <VBox id="listContainer"/>

        </content>

    </Page>

</mvc:View>


